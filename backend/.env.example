# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image Generation (at least one required for image generation)
OPENAI_API_KEY=your_openai_api_key_here
STABILITY_API_KEY=your_stability_api_key_here
FAL_KEY=your_fal_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Image generation defaults (overridden per-request from frontend)
IMAGE_PROVIDER=openai
IMAGE_MODEL=dall-e-3

# CORS: comma-separated frontend URLs allowed to call the backend.
# For Codespaces set this to your forwarded port-3000 URL, e.g.:
# ALLOWED_ORIGINS=https://<codespace-name>-3000.app.github.dev
ALLOWED_ORIGINS=http://localhost:3000
